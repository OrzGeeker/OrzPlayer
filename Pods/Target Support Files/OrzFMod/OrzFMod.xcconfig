CONFIGURATION_BUILD_DIR = ${PODS_CONFIGURATION_BUILD_DIR}/OrzFMod
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
LIBRARY_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/OrzFMod/OrzFMod/FModCapsule/FModAPI/api/lowlevel/lib" "${PODS_ROOT}/OrzFMod/OrzFMod/FModCapsule/FModAPI/api/studio/lib"
OTHER_LDFLAGS = -l"fmod_iphoneos" -l"fmod_iphonesimulator" -l"fmodstudio_iphoneos" -l"fmodstudio_iphonesimulator" -framework "AVFoundation" -framework "AudioToolbox" -framework "UIKit"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_ROOT = ${SRCROOT}
PODS_TARGET_SRCROOT = ${PODS_ROOT}/OrzFMod
PRODUCT_BUNDLE_IDENTIFIER = org.cocoapods.${PRODUCT_NAME:rfc1034identifier}
SKIP_INSTALL = YES
